---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const footerLinks = [
  { href: `${base}${t('footer.href.categories')}`, label: t('footer.categories') },
  { href: `${base}${t('footer.href.tools')}`, label: t('footer.allTools') },
  { href: `${base}${t('footer.href.comparison')}`, label: t('footer.comparison') },
  { href: `${base}${t('footer.href.selfHost')}`, label: t('footer.selfHost') },
  { href: `${base}${t('footer.href.licenseOverview')}`, label: t('footer.licenseOverview') },
  { href: `${base}${t('footer.href.about')}`, label: t('footer.aboutUs') },
  { href: `${base}${t('footer.href.imprint')}`, label: t('footer.imprint') },
  { href: `${base}${t('footer.href.privacy')}`, label: t('footer.privacy') },
];
---

<footer
  class="mt-12"
  style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border)"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <a href={base} class="flex items-center gap-2 no-underline hover:no-underline shrink-0" aria-label={t('nav.home')}>
        <img src={`${base}icon.png`} alt="" class="w-6 h-6 rounded-md" />
        <span class="font-semibold text-sm" style="color: var(--color-text-primary)">
          Safe<span class="gradient-text">Ch</span>
        </span>
      </a>

      <nav class="flex flex-wrap gap-x-4 gap-y-1 text-xs md:text-sm" aria-label={t('footer.navigation')}>
        {footerLinks.map(link => (
          <a
            href={link.href}
            class="no-underline hover:no-underline hover:text-red-400 transition-colors"
            style="color: var(--color-text-secondary)"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="mt-4 pt-3 flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-[11px]" style="border-top: 1px solid var(--color-border); color: var(--color-text-muted)">
      <span>© {year} SafeCh</span>
      <span aria-hidden="true">·</span>
      <span>{t('footer.license')}</span>
    </div>
  </div>
</footer>
