---
import type { Tool } from '../../data/types';
import { Icon } from 'astro-icon/components';
import { getLicenseBadgeClass, getDifficultyBadgeClass } from '../../utils/tools';
import { getSimpleIcon } from '../../utils/icons';
import MaintenanceBadge from '../ui/MaintenanceBadge.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const base = import.meta.env.BASE_URL;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const licenseBadge = getLicenseBadgeClass(tool.license);
const diffBadge = getDifficultyBadgeClass(tool.difficulty);
const diffLabel = t(`difficulty.${tool.difficulty}` as any);
const simpleIcon = getSimpleIcon(tool.simpleIconsSlug ?? tool.slug);

const lastUpdatedDate = tool.lastUpdated ? new Date(tool.lastUpdated) : null;
const monthKey = lastUpdatedDate ? `tool.months.${lastUpdatedDate.getMonth()}` as any : null;
const lastUpdatedLabel = lastUpdatedDate && monthKey ? `${t(monthKey)} ${lastUpdatedDate.getFullYear()}` : null;
const monthsAgo = lastUpdatedDate ? Math.floor((Date.now() - lastUpdatedDate.getTime()) / (1000 * 60 * 60 * 24 * 30)) : 0;
const isStale = monthsAgo > 18;

const toolPath = t('path.tool');

const platformMeta: Record<string, { icon: string; label: string }> = {
  linux: { icon: 'simple-icons:linux', label: 'Linux' },
  windows: { icon: 'simple-icons:windows', label: 'Windows' },
  macos: { icon: 'simple-icons:apple', label: 'macOS' },
  android: { icon: 'simple-icons:android', label: 'Android' },
  ios: { icon: 'simple-icons:apple', label: 'iOS' },
  web: { icon: 'lucide:globe', label: 'Web' },
  docker: { icon: 'simple-icons:docker', label: 'Docker' },
};

function getToolColor(name: string): string {
  let hash = 0;
  for (let i = 0; i < name.length; i++) {
    hash = name.charCodeAt(i) + ((hash << 5) - hash);
  }
  const colors = ['#6366f1', '#a855f7', '#06b6d4', '#22c55e', '#f97316', '#ef4444', '#eab308', '#ec4899', '#8b5cf6', '#14b8a6'];
  return colors[Math.abs(hash) % colors.length];
}

const toolColor = getToolColor(tool.name);
const tagline = (lang === 'zh' && tool.taglineZh) || tool.taglineEn || tool.tagline;
const replacesShown = tool.replacesTools.slice(0, 2);
const replacesExtra = tool.replacesTools.length - replacesShown.length;
---

<a
  href={`${base}${toolPath}/${tool.slug}/`}
  class="tool-card-v2 card-polish block no-underline hover:no-underline group relative"
>
  {/* Top: identity + meta corner */}
  <div class="flex items-start gap-3">
    <div class="icon-chip w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 overflow-hidden">
      {simpleIcon ? (
        <div class="w-5 h-5 flex items-center justify-center tool-simple-icon" style={`color: ${simpleIcon.color}`} set:html={simpleIcon.svg} />
      ) : (
        <>
          <img
            src={`${base}logos/${tool.slug}.png`}
            data-logo-url={tool.logoUrl ?? ''}
            alt=""
            class="w-7 h-7 object-contain tool-logo"
            loading="lazy"
          />
          <span
            class="tool-logo-fallback hidden items-center justify-center w-full h-full text-base font-bold text-white rounded-xl"
            style={`background: ${toolColor}`}
          >
            {tool.name.charAt(0).toUpperCase()}
          </span>
        </>
      )}
    </div>

    <div class="min-w-0 flex-1">
      <h3 class="font-semibold text-[15px] leading-tight truncate" style="color: var(--color-text-primary)">
        {tool.name}
      </h3>
      <p class="text-xs leading-snug line-clamp-2 mt-1" style="color: var(--color-text-secondary)">
        {tagline}
      </p>
    </div>

    <div class="flex flex-col items-end gap-1.5 flex-shrink-0">
      {tool.stars !== undefined && tool.stars > 0 && (
        <span class="flex items-center gap-1 text-[11px] tabular-nums" style="color: var(--color-text-muted)">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          {tool.stars >= 1000 ? `${(tool.stars / 1000).toFixed(1)}k` : tool.stars}
        </span>
      )}
      {tool.maintenanceStatus && (
        <MaintenanceBadge status={tool.maintenanceStatus} note={tool.maintenanceNote} />
      )}
    </div>
  </div>

  {/* Replaces row (subtle) */}
  {replacesShown.length > 0 && (
    <div class="flex flex-wrap items-center gap-1.5 mt-3 text-[11px]" style="color: var(--color-text-muted)">
      <span class="opacity-70">↳</span>
      {replacesShown.map((r, i) => (
        <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded-md bg-orange-500/10 text-orange-300/90 truncate max-w-[140px]">
          {r}
        </span>
      ))}
      {replacesExtra > 0 && (
        <span class="opacity-60">+{replacesExtra}</span>
      )}
    </div>
  )}

  {/* Footer: license + difficulty + selfhost on the left, platforms + date on the right */}
  <div class="flex items-center justify-between gap-2 mt-4 pt-3" style="border-top: 1px solid var(--color-border)">
    <div class="flex flex-wrap items-center gap-1.5 min-w-0">
      <span class:list={['badge', licenseBadge, 'text-[10px] py-0.5 px-1.5']}>{tool.license}</span>
      <span class:list={['badge', diffBadge, 'text-[10px] py-0.5 px-1.5']}>{diffLabel}</span>
      {tool.selfHostable && (
        <span class="inline-flex items-center justify-center w-5 h-5 rounded-md" style="color: var(--color-text-muted); background: var(--color-bg-tertiary)" title={t('tool.selfHostable')}>
          <Icon name="lucide:home" size={11} />
        </span>
      )}
    </div>

    <div class="flex items-center gap-2 flex-shrink-0">
      <div class="flex gap-1 items-center" style="color: var(--color-text-muted)">
        {tool.platforms.slice(0, 4).map(p => {
          const meta = platformMeta[p];
          return meta ? (
            <span title={meta.label}><Icon name={meta.icon} size={13} /></span>
          ) : null;
        })}
      </div>
      {lastUpdatedLabel && (
        <span class:list={['text-[10px] tabular-nums', isStale ? 'text-orange-400' : '']} style={isStale ? '' : 'color: var(--color-text-muted)'}>
          {lastUpdatedLabel}
        </span>
      )}
    </div>
  </div>

  {/* Subtle hover arrow in bottom-right corner */}
  <span class="absolute bottom-3 right-3 text-red-400 opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0 transition-all duration-200 pointer-events-none" aria-hidden="true">
    <Icon name="lucide:arrow-up-right" size={14} />
  </span>
</a>

<script>
  document.querySelectorAll('.tool-logo').forEach(node => {
    const img = node as HTMLImageElement;
    const handleError = () => {
      const logoUrl = img.dataset.logoUrl;
      if (logoUrl && !img.dataset.triedLogoUrl) {
        img.dataset.triedLogoUrl = 'true';
        img.src = logoUrl;
        return;
      }
      img.style.display = 'none';
      const fallback = img.nextElementSibling as HTMLElement | null;
      if (fallback) fallback.style.display = 'flex';
    };
    img.addEventListener('error', handleError);
    if (img.complete && img.naturalWidth === 0) handleError();
  });
</script>
