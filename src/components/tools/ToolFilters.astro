---
import type { Category } from '../../data/types';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations, getCategoryName } from '../../i18n/utils';

interface Props {
  categories: Category[];
  licenses: string[];
}

const { categories, licenses } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="tool-filters sticky z-30 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 mb-6" style="top: 64px">
  <div class="tool-filters-inner py-3" data-active-count="0">
    <div class="flex flex-wrap items-stretch gap-2">
      {/* Search — primary input */}
      <label class="relative flex-1 min-w-[200px]">
        <span class="sr-only">{t('filters.search')}</span>
        <span class="absolute inset-y-0 left-3 flex items-center pointer-events-none" style="color: var(--color-text-muted)">
          <Icon name="lucide:search" size={14} />
        </span>
        <input
          type="text"
          id="filter-search"
          placeholder={t('filters.searchPlaceholder')}
          class="w-full pl-9 pr-9 py-2 rounded-full text-sm outline-none transition-colors"
          style="background: var(--color-bg-tertiary); color: var(--color-text-primary); border: 1px solid var(--color-border)"
        />
        <kbd
          class="filter-search-hint absolute inset-y-0 right-2 my-auto h-5 hidden sm:inline-flex items-center justify-center px-1.5 text-[10px] font-semibold rounded pointer-events-none"
          style="background: var(--color-bg-secondary); color: var(--color-text-muted); border: 1px solid var(--color-border); top: 50%; transform: translateY(-50%)"
        >/</kbd>
      </label>

      {/* Compact dropdowns */}
      <div class="relative flex items-center">
        <Icon name="lucide:folder" size={13} class="absolute left-3 pointer-events-none" style="color: var(--color-text-muted)" />
        <select
          id="filter-category"
          aria-label={t('filters.category')}
          class="appearance-none pl-8 pr-7 py-2 rounded-full text-sm outline-none cursor-pointer transition-colors"
          style="background: var(--color-bg-tertiary); color: var(--color-text-primary); border: 1px solid var(--color-border)"
        >
          <option value="">{t('filters.allCategories')}</option>
          {categories.map(cat => (
            <option value={cat.slug}>{getCategoryName(cat.slug, lang) || cat.name}</option>
          ))}
        </select>
        <Icon name="lucide:chevron-down" size={13} class="absolute right-2.5 pointer-events-none" style="color: var(--color-text-muted)" />
      </div>

      <div class="relative flex items-center">
        <Icon name="lucide:scale" size={13} class="absolute left-3 pointer-events-none" style="color: var(--color-text-muted)" />
        <select
          id="filter-license"
          aria-label={t('filters.license')}
          class="appearance-none pl-8 pr-7 py-2 rounded-full text-sm outline-none cursor-pointer transition-colors"
          style="background: var(--color-bg-tertiary); color: var(--color-text-primary); border: 1px solid var(--color-border)"
        >
          <option value="">{t('filters.allLicenses')}</option>
          {licenses.map(lic => (
            <option value={lic}>{lic}</option>
          ))}
        </select>
        <Icon name="lucide:chevron-down" size={13} class="absolute right-2.5 pointer-events-none" style="color: var(--color-text-muted)" />
      </div>

      <div class="relative flex items-center">
        <Icon name="lucide:arrow-up-down" size={13} class="absolute left-3 pointer-events-none" style="color: var(--color-text-muted)" />
        <select
          id="filter-sort"
          aria-label={t('filters.sort')}
          class="appearance-none pl-8 pr-7 py-2 rounded-full text-sm outline-none cursor-pointer transition-colors"
          style="background: var(--color-bg-tertiary); color: var(--color-text-primary); border: 1px solid var(--color-border)"
        >
          <option value="name">{t('filters.sortName')}</option>
          <option value="stars">{t('filters.sortStars')}</option>
          <option value="date">{t('filters.sortDate')}</option>
        </select>
        <Icon name="lucide:chevron-down" size={13} class="absolute right-2.5 pointer-events-none" style="color: var(--color-text-muted)" />
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-1.5 mt-2.5">
      <button
        type="button"
        class="filter-btn px-2.5 py-1 rounded-full text-xs font-medium transition-colors inline-flex items-center gap-1.5"
        data-filter="selfhost"
        style="background: var(--color-bg-tertiary); color: var(--color-text-secondary); border: 1px solid var(--color-border)"
      >
        <Icon name="lucide:home" size={11} />
        {t('filters.selfHostOnly')}
      </button>
      <button
        type="button"
        class="filter-btn px-2.5 py-1 rounded-full text-xs font-medium transition-colors inline-flex items-center gap-1.5"
        data-filter="easy"
        style="background: var(--color-bg-tertiary); color: var(--color-text-secondary); border: 1px solid var(--color-border)"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
        {t('filters.easySetup')}
      </button>
      <button
        type="button"
        class="filter-btn px-2.5 py-1 rounded-full text-xs font-medium transition-colors inline-flex items-center gap-1.5"
        data-filter="docker"
        style="background: var(--color-bg-tertiary); color: var(--color-text-secondary); border: 1px solid var(--color-border)"
      >
        <Icon name="simple-icons:docker" size={11} />
        {t('filters.dockerAvailable')}
      </button>

      <span class="filter-active-count hidden ml-auto inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-medium tabular-nums" style="background: rgba(239, 68, 68, 0.12); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.25)">
        <span class="filter-active-count-num">0</span> {t('filters.activeCount')}
      </span>
      <button
        type="button"
        class="filter-clear-btn hidden inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium transition-colors"
        style="background: transparent; color: var(--color-text-muted); border: 1px solid var(--color-border)"
      >
        <Icon name="lucide:x" size={11} />
        {t('filters.clearAll')}
      </button>
    </div>
  </div>
</div>

<style>
  .tool-filters {
    /* When sticky-pinned, give it a glass background. We can't use
       :sticky pseudo-classes everywhere, so this triggers based on a
       body-side scroll state set by the page script. */
    transition: background-color 200ms ease-out, backdrop-filter 200ms ease-out, border-color 200ms ease-out;
    border-bottom: 1px solid transparent;
  }
  .tool-filters.is-pinned {
    background-color: rgba(10, 10, 10, 0.78);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--color-border);
  }
  [data-theme='light'] .tool-filters.is-pinned {
    background-color: rgba(255, 255, 255, 0.82);
  }

  /* Hover / focus polish for pill controls */
  #filter-search:focus,
  #filter-category:focus,
  #filter-license:focus,
  #filter-sort:focus {
    border-color: rgba(239, 68, 68, 0.45);
  }
  .filter-btn:hover {
    border-color: rgba(239, 68, 68, 0.35) !important;
    color: var(--color-text-primary) !important;
  }
  .filter-btn[data-active="true"] {
    background-color: rgba(239, 68, 68, 0.15) !important;
    border-color: rgba(239, 68, 68, 0.45) !important;
    color: #fca5a5 !important;
  }
  .filter-clear-btn:hover {
    color: var(--color-text-primary) !important;
    border-color: rgba(239, 68, 68, 0.35) !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const root = document.querySelector('.tool-filters') as HTMLElement | null;
    const inner = document.querySelector('.tool-filters-inner') as HTMLElement | null;
    const searchInput = document.getElementById('filter-search') as HTMLInputElement;
    const categorySelect = document.getElementById('filter-category') as HTMLSelectElement;
    const licenseSelect = document.getElementById('filter-license') as HTMLSelectElement;
    const sortSelect = document.getElementById('filter-sort') as HTMLSelectElement;
    const filterBtns = document.querySelectorAll('.filter-btn');
    const clearBtn = document.querySelector('.filter-clear-btn') as HTMLButtonElement | null;
    const activeCountEl = document.querySelector('.filter-active-count') as HTMLElement | null;
    const activeCountNum = document.querySelector('.filter-active-count-num') as HTMLElement | null;
    const toolCards = document.querySelectorAll('[data-tool-card]');

    const activeFilters = new Set<string>();

    function updateActiveCount() {
      let n = 0;
      if (searchInput?.value.trim()) n++;
      if (categorySelect?.value) n++;
      if (licenseSelect?.value) n++;
      n += activeFilters.size;
      if (activeCountNum) activeCountNum.textContent = String(n);
      if (activeCountEl) activeCountEl.classList.toggle('hidden', n === 0);
      if (clearBtn) clearBtn.classList.toggle('hidden', n === 0);
    }

    function applyFilters() {
      const search = searchInput?.value.toLowerCase() ?? '';
      const category = categorySelect?.value ?? '';
      const license = licenseSelect?.value ?? '';

      toolCards.forEach((card) => {
        const el = card as HTMLElement;
        const name = (el.dataset.toolName ?? '').toLowerCase();
        const cats = (el.dataset.toolCategories ?? '').split(',');
        const lic = el.dataset.toolLicense ?? '';
        const selfHost = el.dataset.toolSelfhost === 'true';
        const diff = el.dataset.toolDifficulty ?? '';
        const platforms = (el.dataset.toolPlatforms ?? '').split(',');

        let show = true;
        if (search && !name.includes(search)) show = false;
        if (category && !cats.includes(category)) show = false;
        if (license && lic !== license) show = false;
        if (activeFilters.has('selfhost') && !selfHost) show = false;
        if (activeFilters.has('easy') && diff !== 'einfach') show = false;
        if (activeFilters.has('docker') && !platforms.includes('docker')) show = false;

        el.style.display = show ? '' : 'none';
      });
      updateActiveCount();
    }

    searchInput?.addEventListener('input', applyFilters);
    categorySelect?.addEventListener('change', applyFilters);
    licenseSelect?.addEventListener('change', applyFilters);
    sortSelect?.addEventListener('change', applyFilters);

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const filter = el.dataset.filter ?? '';
        if (activeFilters.has(filter)) {
          activeFilters.delete(filter);
          el.dataset.active = 'false';
        } else {
          activeFilters.add(filter);
          el.dataset.active = 'true';
        }
        applyFilters();
      });
    });

    clearBtn?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      if (categorySelect) categorySelect.value = '';
      if (licenseSelect) licenseSelect.value = '';
      activeFilters.clear();
      filterBtns.forEach((btn) => ((btn as HTMLElement).dataset.active = 'false'));
      applyFilters();
    });

    // Pinned-state detection: toggle the glass background once the bar
    // begins overlapping content (i.e. its sticky offset has kicked in).
    if (root && inner) {
      const sentinel = document.createElement('div');
      sentinel.style.cssText = 'position:absolute; top:0; height:1px; width:1px;';
      root.parentElement?.insertBefore(sentinel, root);
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            root.classList.toggle('is-pinned', !entry.isIntersecting);
          }
        },
        { rootMargin: '-65px 0px 0px 0px', threshold: 0 },
      );
      io.observe(sentinel);
    }

    // Keyboard shortcuts: '/' focuses the search input (GitHub-style),
    // Esc clears the search and blurs. Ignored while the user is
    // already typing in any input/select/textarea or contenteditable.
    const hint = document.querySelector('.filter-search-hint') as HTMLElement | null;
    document.addEventListener('keydown', (ev) => {
      const target = ev.target as HTMLElement | null;
      const editable =
        target &&
        (target.tagName === 'INPUT' ||
          target.tagName === 'TEXTAREA' ||
          target.tagName === 'SELECT' ||
          (target as HTMLElement).isContentEditable);

      if (ev.key === '/' && !editable && !ev.ctrlKey && !ev.metaKey && !ev.altKey) {
        ev.preventDefault();
        searchInput?.focus();
        return;
      }
      if (ev.key === 'Escape' && document.activeElement === searchInput) {
        if (searchInput && searchInput.value) {
          searchInput.value = '';
          applyFilters();
        }
        searchInput?.blur();
      }
    });
    // Hide the '/' hint while the input has focus to reduce noise.
    searchInput?.addEventListener('focus', () => {
      if (hint) hint.style.opacity = '0';
    });
    searchInput?.addEventListener('blur', () => {
      if (hint) hint.style.opacity = '';
    });
  });
</script>
