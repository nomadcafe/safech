---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

interface Props {
  status?: 'active' | 'maintained' | 'slow' | 'restricted' | 'archived';
  note?: string;
}

const { status, note } = Astro.props;

if (!status) return;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const badgeConfig: Record<string, { labelKey: string; classes: string }> = {
  active: { labelKey: 'maintenance.active', classes: 'bg-green-500/20 text-green-400 border-green-500/30' },
  maintained: { labelKey: 'maintenance.maintained', classes: 'bg-blue-500/20 text-blue-400 border-blue-500/30' },
  slow: { labelKey: 'maintenance.slow', classes: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30' },
  restricted: { labelKey: 'maintenance.restricted', classes: 'bg-orange-500/20 text-orange-400 border-orange-500/30' },
  archived: { labelKey: 'maintenance.archived', classes: 'bg-red-500/20 text-red-400 border-red-500/30' },
};

const config = badgeConfig[status];
if (!config) return;
---

<span
  class:list={['inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium border', config.classes]}
  title={note ?? ''}
>
  {t(config.labelKey as any)}
</span>
