---
import BaseLayout from '../../components/layout/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="404 – 页面未找到 – SafeCh">
  <div class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="text-center">
      <div class="text-8xl font-bold gradient-text mb-4">404</div>
      <h1 class="text-2xl font-bold mb-3" style="color: var(--color-text-primary)">
        页面未找到
      </h1>
      <p class="text-lg mb-8 max-w-md mx-auto" style="color: var(--color-text-secondary)">
        这个页面不存在 — 就像使用专有软件的那些借口一样。
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${base}zh/`}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium no-underline hover:no-underline bg-red-600 hover:bg-red-500 text-white transition-all"
        >
          ← 返回首页
        </a>
        <a
          href={`${base}zh/tools/`}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium no-underline hover:no-underline border border-red-500/50 text-red-400 hover:bg-red-500/10 transition-all"
        >
          查看全部工具
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
