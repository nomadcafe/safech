---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import SearchModal from '../../components/ui/SearchModal.astro';
import ToolCard from '../../components/tools/ToolCard.astro';
import ToolRow from '../../components/tools/ToolRow.astro';
import ToolFilters from '../../components/tools/ToolFilters.astro';
import { Icon } from 'astro-icon/components';
import { allTools } from '../../data/tools/index';
import { categories } from '../../data/categories';
import { getUniquelicenses, sortTools } from '../../utils/tools';
import { useTranslations } from '../../i18n/utils';

const base = import.meta.env.BASE_URL;
const sortedTools = sortTools(allTools, 'name');
const licenses = getUniquelicenses(allTools);
const t = useTranslations('en');
---

<BaseLayout title="All Tools – SafeCh" description="Browse all free open-source alternatives. Filter by category, license, platform and more.">
  <SearchModal />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    <div class="mb-8">
      <h1 class="text-4xl font-bold mb-4" style="color: var(--color-text-primary)">
        All <span class="gradient-text">Tools</span>
      </h1>
      <p class="text-lg" style="color: var(--color-text-secondary)">
        {allTools.length} free open-source alternatives to proprietary software.
      </p>
    </div>

    <ToolFilters categories={categories} licenses={licenses} />

    <div class="flex justify-end mb-4">
      <div
        role="group"
        aria-label={t('filters.viewToggleLabel')}
        class="inline-flex rounded-lg overflow-hidden"
        style="background: var(--color-bg-secondary); border: 1px solid var(--color-border)"
      >
        <button
          type="button"
          class="view-toggle-btn px-3 py-1.5 text-xs font-medium inline-flex items-center gap-1.5 transition-colors"
          data-view="grid"
          aria-pressed="true"
          style="color: var(--color-text-primary)"
        >
          <Icon name="lucide:layout-grid" size={14} />
          {t('filters.viewGrid')}
        </button>
        <button
          type="button"
          class="view-toggle-btn px-3 py-1.5 text-xs font-medium inline-flex items-center gap-1.5 transition-colors"
          data-view="list"
          aria-pressed="false"
          style="color: var(--color-text-muted)"
        >
          <Icon name="lucide:list" size={14} />
          {t('filters.viewList')}
        </button>
      </div>
    </div>

    <div id="tools-container" data-view="grid">
      <div class="tools-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 stagger-fade">
        {sortedTools.map((tool) => (
          <div
            data-tool-card
            data-tool-name={tool.name}
            data-tool-categories={tool.categories.join(',')}
            data-tool-license={tool.license}
            data-tool-selfhost={String(tool.selfHostable)}
            data-tool-difficulty={tool.difficulty}
            data-tool-platforms={tool.platforms.join(',')}
          >
            <div class="tool-card-view"><ToolCard tool={tool} /></div>
            <div class="tool-row-view"><ToolRow tool={tool} /></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Default (grid view): show cards, hide rows. */
  #tools-container[data-view="grid"] .tool-row-view { display: none; }
  #tools-container[data-view="grid"] .tool-card-view { display: block; }

  /* List view: collapse the grid into a single column of dense rows. */
  #tools-container[data-view="list"] .tools-grid {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-bg-card);
    overflow: hidden;
  }
  #tools-container[data-view="list"] .tools-grid > [data-tool-card] {
    animation: none;
    opacity: 1;
  }
  #tools-container[data-view="list"] .tool-card-view { display: none; }
  #tools-container[data-view="list"] .tool-row-view { display: block; }
  #tools-container[data-view="list"] .tool-row-view :global(.tool-row) {
    border-bottom: 1px solid var(--color-border);
  }
  #tools-container[data-view="list"] .tools-grid > [data-tool-card]:last-child .tool-row-view :global(.tool-row) {
    border-bottom: none;
  }

  .view-toggle-btn[aria-pressed="true"] {
    background: var(--color-bg-tertiary);
  }
</style>

<script>
  (function () {
    const container = document.getElementById('tools-container');
    const buttons = document.querySelectorAll('.view-toggle-btn');
    if (!container || buttons.length === 0) return;

    const STORAGE_KEY = 'tools-view-mode';
    const saved = localStorage.getItem(STORAGE_KEY);
    const initial = saved === 'list' || saved === 'grid' ? saved : 'grid';

    function setView(mode: string) {
      container!.setAttribute('data-view', mode);
      buttons.forEach((btn) => {
        const el = btn as HTMLButtonElement;
        const active = el.dataset.view === mode;
        el.setAttribute('aria-pressed', active ? 'true' : 'false');
        el.style.color = active ? 'var(--color-text-primary)' : 'var(--color-text-muted)';
      });
      try {
        localStorage.setItem(STORAGE_KEY, mode);
      } catch {
        /* ignore quota / privacy-mode errors */
      }
    }

    setView(initial);
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = (btn as HTMLButtonElement).dataset.view ?? 'grid';
        setView(mode);
      });
    });
  })();
</script>
